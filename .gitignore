# 빌드 산출물 (Build outputs)
[Bb]in/
[Oo]bj/
[Rr]elease/
[Dd]ebug/

# Visual Studio / VS Code 설정
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates

# 프로젝트별 특정 무시 항목
/Client/
/.vs/iocp/FileContentIndex

# 로그 및 임시 파일
*.log
*.tmp
